    {
      "parameters": {
        "jsCode": "// Получаем текст сообщения\nconst rawText = $json.message?.text || \"\";\n\n// Разбиваем по строкам и очищаем\nconst lines = rawText\n  .split('\\n')\n  .map(line => line.trim())\n  .filter(line => line.length > 0);\n\n// Определяем use case\nlet use_case = \"unknown\";\n\nif (lines.length === 4) {\n  use_case = \"youtube\";\n} else if (lines.length >= 5) {\n  use_case = \"teacher\";\n}\n\n// Получаем chat_id\nconst chat_id = $json.message?.chat?.id;\n\n// Формируем результат\nlet result = {\n  use_case,\n  chat_id\n};\n\n// Заполняем поля в зависимости от сценария\nif (use_case === \"youtube\") {\n  result.project_name = lines[0] || \"\";\n  result.genre = lines[1] || \"\";\n  result.duration = lines[2] || \"\";\n  result.description = lines.slice(3).join(\" \") || \"\";\n}\n\nif (use_case === \"teacher\") {\n  result.project_name = lines[0] || \"\";\n  result.topic = lines[1] || \"\";\n  result.duration = lines[2] || \"\";\n  result.style = lines[3] || \"\";\n  result.description = lines.slice(4).join(\" \") || \"\";\n}\n\n// ВАЖНО: оборачиваем результат в \"json\", чтобы n8n корректно воспринимала\nreturn [\n  {\n    json: result\n  }\n];"
      },
