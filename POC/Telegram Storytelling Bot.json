    {
      "parameters": {
        "jsCode": "// ── STEP 9: Format backend response for Telegram ──\nconst response = $json;\nconst chatId   = $('Validate & Parse Input').first().json.chat_id;\nconst segments = response.segments || [];\n\nfunction escMd(text) {\n  if (!text) return '';\n  return String(text).replace(/[_*[\\]()~`>#+\\-=|{}.!\\\\]/g, '\\\\$&');\n}\n\nlet msg = '🎬 *Your Story is Ready*\\n\\n';\n\nif (segments.length > 0) {\n  msg += '🎞 *Segments:*\\n\\n';\n  segments.forEach((seg, i) => {\n    msg += `${i + 1}\\\\. ${escMd(seg.text)}\\n`;\n    if (seg.audio_url) {\n      msg += `🔊 Audio: ${escMd(seg.audio_url)}\\n`;\n    }\n    msg += '\\n';\n  });\n} else if (response.script) {\n  msg += escMd(response.script);\n} else {\n  msg += '_No content was returned by the backend\\\\._';\n}\n\n// ── Fact Check Report ──\nconst factReport = response.fact_check_report || [];\nif (factReport.length > 0) {\n  msg += '──────────────────────\\n';\n  msg += '🔍 *Fact Check Report*\\n\\n';\n  factReport.forEach((item, i) => {\n    const verdictEmoji  = item.final_verdict === 'true'  ? '✅' : item.final_verdict === 'false' ? '❌' : '⚠️';\n    const checkedEmoji  = item.checked              ? '✔️' : '✖️';\n    const manualEmoji   = item.requires_manual_check ? '🔎 Yes' : '✅ No';\n    const correctedLine = item.was_corrected\n      ? `\\n📝 *Corrected to:* ${escMd(item.corrected_to)}`\n      : '';\n    msg += `*${i + 1}\\\\. Claim:*\\n`;\n    msg += `_${escMd(item.claim)}_\\n\\n`;\n    msg += `${checkedEmoji} *Checked:* ${item.checked ? 'Yes' : 'No'}\\n`;\n    msg += `${verdictEmoji} *Verdict:* ${escMd(item.final_verdict)}${correctedLine}\\n`;\n    msg += `🔎 *Manual check required:* ${manualEmoji}\\n`;\n    msg += '\\n';\n  });\n}\n\n// ── Video URL ──\nif (response.video_url) {\n  msg += '──────────────────────\\n';\n  msg += `🎥 *Video is Ready\\\\!*\\n\\n`;\n  msg += `▶️ [Watch the video](${response.video_url})\\n`;\n}\n\nreturn [{ json: { ...response, chat_id: chatId, formatted_text: msg.trim() } }];"
      },
