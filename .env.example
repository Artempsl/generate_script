# =============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
#
# This file shows which environment variables are required for the Pinecone
# ingestion module.
#
# IMPORTANT: Set these as Windows environment variables (not in a .env file)
# 
# To set Windows environment variables:
# 1. Open PowerShell as Administrator
# 2. Run: [System.Environment]::SetEnvironmentVariable('VARIABLE_NAME', 'your-value', 'User')
# 3. Restart your terminal/IDE
#
# OR use System Properties > Environment Variables GUI
#
# =============================================================================

# =============================================================================
# PHASE 1: PINECONE INGESTION MODULE
# =============================================================================

# Cohere API Key (obtain from: https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=your-cohere-api-key-here

# Pinecone API Key (obtain from: https://app.pinecone.io/)
PINECONE_API_KEY=your-pinecone-api-key-here

# =============================================================================
# PHASE 2: AGENT BACKEND (for n8n integration)
# =============================================================================

# OpenAI API Key (obtain from: https://platform.openai.com/api-keys)
# Used for: GPT-4o-mini script generation, outline creation, context synthesis
# NOTE: Set as Windows global environment variable for testing
OPENAI_API_KEY=your-openai-api-key-here

# SerpAPI Key (obtain from: https://serpapi.com/manage-api-key) [OPTIONAL]
# Used for: Web search (only for videos > 10 minutes)
# If not set, web search will be skipped (agent continues without it)
# NOTE: Set as Windows global environment variable for testing
SERPAPI_API_KEY=your-serpapi-api-key-here
